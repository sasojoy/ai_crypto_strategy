


# Telegram Bot Configuration
# Telegram Configuration
# 1. Create a bot via @BotFather on Telegram to get your TOKEN.
# 2. Send a message to your bot and visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates to find your CHAT_ID.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Binance API Configuration (Optional for Dry Run)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here


